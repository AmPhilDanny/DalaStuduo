# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Redis (for BullMQ job queue — use Upstash or Render Redis)
REDIS_URL=redis://localhost:6379

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...

# AI Provider Keys (server-side only, never exposed to client)
AI_OPENROUTER_KEY=
AI_MISTRAL_KEY=
AI_OPENAI_KEY=
AI_GROQ_KEY=
AI_GOOGLE_KEY=
AI_TOGETHERAI_KEY=

# Server
PORT=4001
NODE_ENV=development
